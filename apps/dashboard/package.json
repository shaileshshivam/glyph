{
  "name": "@glyph/dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "The deployable Glyph dashboard — a TanStack Start app that signs in, reads a glyph.config.ts, and renders the CMS UI.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@glyph/auth-env": "workspace:*",
    "@glyph/core": "workspace:*",
    "@glyph/storage-github": "workspace:*",
    "@glyph/theme-mithila": "workspace:*",
    "@glyph/ui": "workspace:*",
    "@tanstack/react-router": "1.168.22",
    "@tanstack/react-start": "1.167.41",
    "@tanstack/router-plugin": "1.167.22",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "5.2.0",
    "typescript": "5.7.2",
    "vite": "7.0.0",
    "vitest": "2.1.8"
  }
}
