// glyph.config.ts.example
//
// Copy this file to `glyph.config.ts` at the monorepo root, fill in the fields,
// and restart the dashboard. The dashboard reads this file at startup to wire
// up its adapters.

import { envAuth } from '@glyph/auth-env';
import { defineConfig } from '@glyph/core';
import { githubStorage } from '@glyph/storage-github';

export default defineConfig({
  storage: githubStorage({
    owner: process.env.GLYPH_GITHUB_OWNER ?? 'your-github-username',
    repo: process.env.GLYPH_GITHUB_REPO ?? 'your-content-repo',
    branch: process.env.GLYPH_GITHUB_BRANCH ?? 'main',
    token: process.env.GITHUB_TOKEN ?? '',
    // contentRoot: 'src/content',
  }),
  auth: envAuth({
    passwordEnvVar: 'GLYPH_PASSWORD',
    sessionSecretEnvVar: 'GLYPH_SESSION_SECRET',
  }),
  workspace: {
    name: 'My workspace',
  },
});
