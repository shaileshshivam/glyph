{
  "name": "glyph",
  "version": "0.0.0",
  "private": true,
  "description": "A headless CMS with an adapter-first architecture.",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "ci": "turbo build test typecheck && biome ci ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.1.0",
    "@changesets/cli": "2.27.9",
    "turbo": "2.3.0",
    "typescript": "5.7.2"
  }
}
