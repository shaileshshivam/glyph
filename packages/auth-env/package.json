{
  "name": "@glyph/auth-env",
  "version": "0.0.0",
  "description": "Single-user password authentication for Glyph — reads password from an env var, signs sessions with HMAC. Simplest viable auth for self-hosted deployments.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaileshshivam/glyph.git",
    "directory": "packages/auth-env"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@glyph/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false
}
