{
  "name": "@glyph/core",
  "version": "0.1.0",
  "description": "Framework-agnostic core for Glyph CMS — adapter interfaces, plugin host, config helpers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaileshshivam/glyph.git",
    "directory": "packages/core"
  },
  "homepage": "https://glyph.dev",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false
}
