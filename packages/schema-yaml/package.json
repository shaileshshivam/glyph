{
  "name": "@glyph/schema-yaml",
  "version": "0.1.0",
  "description": "SchemaAdapter implementation for Glyph — parses YAML collection schemas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaileshshivam/glyph.git",
    "directory": "packages/schema-yaml"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@glyph/core": "workspace:*",
    "js-yaml": "4.1.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.6.0",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false
}
