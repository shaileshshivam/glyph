{
  "name": "@glyph/ui",
  "version": "0.0.0",
  "description": "React component library for Glyph — Base UI primitives, CodeMirror editor, themeable via CSS variables.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shaileshshivam/glyph.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-beta.3",
    "@codemirror/commands": "6.7.1",
    "@codemirror/lang-markdown": "6.3.1",
    "@codemirror/language": "6.10.3",
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.35.0",
    "@lezer/highlight": "^1.2.3",
    "clsx": "2.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "jsdom": "26.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": [
    "**/*.css"
  ]
}
